{
  "name": "ironflow/skeleton",
  "description": "Skeleton pour démarrer un nouveau projet avec IronFlow Framework",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "IronFlow Framework",
      "email": "ironflow.framework@gmail.com"
    }
  ],
  "require": {
    "ironflow/framework": "^1",
    "php": "^8.2",
    "phpunit/phpunit": "^10"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\": "database/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "setup-directories": [
      "@php vendor/ironflow/framework/src/scripts/setup_directories.php"
    ],
    "check-os-and-chmod": [
      "@php vendor/ironflow/framework/src/scripts/check_os_and_chmod.php"
    ],
    "run-npm-install": [
      "bash vendor/ironflow/framework/src/scripts/run_npm_install.sh"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
      "@setup-directories",
      "@check-os-and-chmod",
      "@run-npm-install"
    ],
    "post-create-project-cmd": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
      "@setup-directories",
      "@check-os-and-chmod",
      "@run-npm-install"
    ],
    "test": "phpunit"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
