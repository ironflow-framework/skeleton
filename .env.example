APP_NAME=IronFlow
APP_VERSION=1.0.0
APP_ENV=development
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr_FR
APP_FALLBACK_LOCALE=en_US
APP_FAKER_LOCALE=fr_FR
APP_CIPHER=AES-256-CBC

TIMEZONE=Africa/Brazzaville

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ironflow
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=file
# CACHE_HOST=127.0.0.1
# CACHE_PORT=
# CACHE_USERNAME=Redis
# CACHE_PASSWORD=
CACHE_PREFIX=ironflow_

SESSION_DRIVER=file
SESSION_COOKIE=ironflow_session
SESSION_LIFETIME=120
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_CONNECTION=null
QUEUE_CONNECTION=sync

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"