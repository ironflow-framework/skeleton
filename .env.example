APP_NAME=IronFlow
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost
APP_KEY=
APP_TIMEZONE=Africa/Brazzaville
APP_VERSION=1.0.0
APP_LOCALE=fr_FR
APP_FALLBACK_LOCALE=en_US
APP_FAKER_LOCALE=fr_FR
APP_CIPHER=AES-256-CBC

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ironflow
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_COOKIE=ironflow_session
SESSION_LIFETIME=120
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_CONNECTION=null
QUEUE_CONNECTION=sync

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

STRIPE_KEY=
STRIPE_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET= 